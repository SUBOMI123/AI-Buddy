{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI Buddy",
  "version": "0.1.3",
  "identifier": "com.aibuddy.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "overlay",
        "title": "AI Buddy",
        "url": "/",
        "width": 300,
        "height": 900,
        "x": null,
        "y": 0,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visibleOnAllWorkspaces": true,
        "focus": false,
        "visible": false,
        "resizable": false,
        "skipTaskbar": true,
        "shadow": false
      },
      {
        "label": "region-select",
        "url": "/#/select",
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "focus": true,
        "visible": false,
        "resizable": false,
        "skipTaskbar": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' https://ai-buddy-proxy.subomi-bashorun.workers.dev wss://api.assemblyai.com https://api.assemblyai.com https://api.elevenlabs.io wss://api.elevenlabs.io"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "infoPlist": "./Info.plist",
      "entitlements": "./entitlements.plist",
      "signingIdentity": "Developer ID Application: Oreski Group LLC (8Q87GSTTX3)"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDk1OUYyQTc0RUQwNUE3QTcKUldTbnB3WHRkQ3FmbGNuVkFpMTRteThqTWNxSktHWlhZK3diQUhWNW9EbDZUcWRER1BNWE50NmsK",
      "endpoints": [
        "https://github.com/SUBOMI123/AI-Buddy/releases/latest/download/latest.json"
      ]
    }
  }
}
