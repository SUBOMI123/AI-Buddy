{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI Buddy",
  "version": "0.1.0",
  "identifier": "com.aibuddy.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "overlay",
        "title": "AI Buddy",
        "url": "/",
        "width": 300,
        "height": 900,
        "x": null,
        "y": 0,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visibleOnAllWorkspaces": true,
        "focus": false,
        "visible": false,
        "resizable": false,
        "skipTaskbar": true,
        "shadow": false
      },
      {
        "label": "region-select",
        "url": "/#/select",
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "focus": true,
        "visible": false,
        "resizable": false,
        "skipTaskbar": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' https://*.workers.dev wss://api.assemblyai.com https://api.assemblyai.com https://api.elevenlabs.io wss://api.elevenlabs.io"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "infoPlist": "./Info.plist",
      "entitlements": "./entitlements.plist",
      "signingIdentity": "Developer ID Application: Oreski Group LLC (8Q87GSTTX3)"
    }
  },
  "plugins": {
    "_comment_updater": "Auto-updater intentionally disabled for beta. Re-enable in Phase 15 after running: cargo tauri signer generate -w ~/.tauri/ai-buddy.key"
  }
}
